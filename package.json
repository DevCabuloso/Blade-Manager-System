{
  "name": "blademanager",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"nodemon backend/server.js\" \"wait-on http://localhost:5173 && start chrome http://localhost:5173\"",
    "build": "vite build",
    "serve": "vite preview",
    "backend": "node backend/server.js",
    "dev:backend": "nodemon backend/server.js",
    "setup": "npm install && cd backend && npm install",
    "postinstall": "cd backend && npm install",
    "diagnose": "node backend/diagnose.js"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@supabase/supabase-js": "^2.76.1",
    "axios": "^1.11.0",
    "body-parser": "^2.2.0",
    "chart.js": "^4.5.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "jspdf": "^3.0.2",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.10",
    "path-to-regexp": "^8.3.0",
    "twilio": "^5.7.3",
    "validator": "^13.15.15",
    "vue": "^3.5.22",
    "vue-cal": "^4.10.2",
    "vue-chartjs": "^5.3.2",
    "vue-router": "^4.5.1",
    "vue-toastification": "^2.0.0-rc.5",
    "vuetify": "^4.0.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.10",
    "terser": "^5.46.0",
    "vite": "^6.3.5",
    "wait-on": "^9.0.1"
  }
