# Variáveis de Ambiente - Copie para .env e customize conforme sua infraestrutura

# ====== DESENVOLVIMENTO (localhost) ======
VITE_BACKEND_URL=http://localhost:8000
VITE_FRONTEND_URL=http://localhost:5173

# ====== PRODUÇÃO (Domínio Customizado) ======
# Descomente e customize para usar um domínio/URL real:
# VITE_BACKEND_URL=https://api.seudominio.com
# VITE_FRONTEND_URL=https://www.seudominio.com

# Nota: Certifique-se também de atualizar o arquivo backend/.env com as URLs correspondentes
